<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>박세준 — 채용 포트폴리오 2026</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css" />
  <link rel="stylesheet" href="./styles/reset.css" />
  <style>
/* ═══════════════════════════════════════
   TOSS DESIGN SYSTEM
═══════════════════════════════════════ */
:root {
  --blue:      #3182f6;
  --blue-dark: #1b64da;
  --dark:      #191f28;
  --dark2:     #333d4b;
  --muted:     #4e5968;
  --muted2:    #6b7684;
  --muted3:    #8b95a1;
  --line:      #b0b8c1;
  --line-soft: #d1d6db;
  --bg:        #f9fafb;
  --white:     #ffffff;

  --font: 'Pretendard', -apple-system, BlinkMacSystemFont, sans-serif;
  --max-w: 1040px;
  --pad: clamp(24px, 5vw, 80px);
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body { font-family: var(--font); color: var(--dark); background: var(--white); -webkit-font-smoothing: antialiased; }
a { text-decoration: none; color: inherit; }

.p-container { max-width: var(--max-w); margin: 0 auto; padding: 0 var(--pad); }

/* ───────────────────────────────────────
   NAV
─────────────────────────────────────── */
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: rgba(255,255,255,0.92);
  backdrop-filter: saturate(180%) blur(10px);
  border-bottom: 1px solid var(--line-soft);
}

.nav-inner {
  max-width: var(--max-w);
  margin: 0 auto;
  padding: 0 var(--pad);
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.nav-logo {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--dark);
  letter-spacing: -0.01em;
}

.nav-links {
  display: flex;
  gap: 28px;
}

.nav-links a {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--muted2);
  transition: color 0.15s;
}

.nav-links a:hover { color: var(--dark); }

/* ───────────────────────────────────────
   01. HERO — 풀뷰포트
─────────────────────────────────────── */
.hero {
  position: relative;
  width: 100%;
  min-height: 100vh;
  display: flex;
  align-items: center;
  background: var(--white);
  overflow: hidden;
}

.hero-gradient {
  position: absolute;
  top: 0; left: 0;
  width: 100%;
  height: 500px;
  background: linear-gradient(180deg, var(--white) 0%, var(--white) 59px, rgba(255,255,255,0) 100%);
  pointer-events: none;
  z-index: 1;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 70% 50%, rgba(49,130,246,0.07) 0%, transparent 70%);
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  padding: 120px 0 160px;
}

.hero-eyebrow {
  display: inline-block;
  font-size: 1.1rem;
  font-weight: 700;
  line-height: 1.3;
  color: var(--blue);
  margin-bottom: 20px;
}

.hero-title {
  font-size: clamp(2.6rem, 6vw, 4.8rem);
  font-weight: 700;
  line-height: 1.3;
  color: var(--dark);
  margin-bottom: 28px;
  letter-spacing: -0.02em;
}

.hero-sub {
  font-size: clamp(1.1rem, 2vw, 1.45rem);
  font-weight: 600;
  line-height: 1.6;
  color: var(--muted2);
  max-width: 540px;
  margin-bottom: 48px;
}

.hero-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.hero-tag {
  font-size: 0.88rem;
  font-weight: 600;
  color: var(--blue);
  background: rgba(49,130,246,0.08);
  border-radius: 100px;
  padding: 8px 18px;
  transition: background 0.15s;
}

.hero-tag:hover { background: rgba(49,130,246,0.15); }

/* 우측 숫자 장식 */
.hero-deco {
  position: absolute;
  right: var(--pad);
  bottom: 80px;
  font-size: clamp(8rem, 20vw, 18rem);
  font-weight: 800;
  color: rgba(49,130,246,0.04);
  line-height: 1;
  letter-spacing: -0.04em;
  pointer-events: none;
  user-select: none;
}

/* ───────────────────────────────────────
   공통 섹션 패턴
─────────────────────────────────────── */
.section {
  padding: clamp(80px, 15vw, 200px) 0;
  position: relative;
  overflow: hidden;
}

.section--bg { background: var(--bg); }
.section--dark { background: var(--dark); }

.section-eyebrow {
  display: block;
  font-size: 1.05rem;
  font-weight: 700;
  line-height: 1.3;
  color: var(--blue);
  margin-bottom: 16px;
}

.section-eyebrow--white { color: rgba(255,255,255,0.55); }

.section-title {
  font-size: clamp(2rem, 4.5vw, 3.6rem);
  font-weight: 700;
  line-height: 1.4;
  color: var(--dark);
  margin-bottom: 16px;
  letter-spacing: -0.02em;
}

.section-title--white { color: var(--white); }

.section-sub {
  font-size: clamp(1rem, 1.8vw, 1.3rem);
  font-weight: 600;
  line-height: 1.6;
  color: var(--muted2);
}

.section-sub--white { color: rgba(255,255,255,0.55); }

/* ───────────────────────────────────────
   02. RESUME — 실적 카드 그리드
─────────────────────────────────────── */
.resume-layout {
  display: flex;
  flex-wrap: wrap;
  gap: 28px;
  margin-top: 70px;
  align-items: stretch;
}

.resume-card {
  flex: 1 1 calc(50% - 14px);
  min-width: 280px;
  background: var(--white);
  border-radius: 16px;
  padding: 40px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.06);
  overflow: hidden;
}

.resume-card--full { flex: 1 1 100%; }

.resume-card-label {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 20px;
  display: block;
}

.resume-card-title {
  font-size: clamp(1.1rem, 2vw, 1.5rem);
  font-weight: 700;
  color: var(--dark2);
  line-height: 1.4;
  margin-bottom: 16px;
}

.r2-list {
  display: grid;
  grid-template-columns: 60px 1fr;
  gap: 8px 16px;
}

.r2-list dt {
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--muted3);
  padding-top: 2px;
}

.r2-list dd {
  font-size: 0.9rem;
  color: var(--dark2);
  line-height: 1.6;
}

.exp-stack { display: flex; flex-direction: column; gap: 20px; }

.exp-item {
  display: grid;
  grid-template-columns: 120px 1fr;
  gap: 12px;
  align-items: start;
  padding-bottom: 20px;
  border-bottom: 1px solid var(--line-soft);
}

.exp-item:last-child { border-bottom: none; padding-bottom: 0; }

.exp-period {
  font-size: 0.74rem;
  color: var(--muted3);
  padding-top: 3px;
  line-height: 1.5;
}

.exp-title {
  font-size: 0.95rem;
  font-weight: 700;
  color: var(--dark2);
  margin-bottom: 3px;
  display: block;
}

.exp-sub {
  font-size: 0.8rem;
  color: var(--muted2);
  line-height: 1.5;
}

/* 수상 */
.award-list { display: flex; flex-direction: column; gap: 12px; }
.award-item {
  display: flex;
  gap: 14px;
  align-items: baseline;
  font-size: 0.9rem;
}
.award-year {
  font-size: 0.74rem;
  font-weight: 700;
  color: var(--blue);
  letter-spacing: 0.05em;
  min-width: 30px;
  flex-shrink: 0;
}
.award-text { color: var(--dark2); line-height: 1.5; }

/* 총무 역할 */
.role-grid2 { display: flex; flex-direction: column; gap: 10px; }
.role-item2 {
  display: flex;
  gap: 14px;
  padding: 12px 0;
  border-bottom: 1px solid var(--line-soft);
  align-items: start;
  font-size: 0.88rem;
}
.role-item2:last-child { border-bottom: none; }
.role-tag {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--blue);
  background: rgba(49,130,246,0.08);
  border-radius: 6px;
  padding: 4px 10px;
  white-space: nowrap;
  letter-spacing: 0.03em;
  flex-shrink: 0;
}
.role-desc { color: var(--dark2); line-height: 1.6; }

/* 스킬 */
.skill-grid2 { display: flex; flex-direction: column; gap: 12px; }
.skill-item2 { display: flex; gap: 14px; align-items: start; font-size: 0.88rem; }
.skill-cat2 {
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--muted3);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  min-width: 52px;
  padding-top: 2px;
}
.skill-val { color: var(--dark2); line-height: 1.6; }

/* ───────────────────────────────────────
   03. 섹션 구분 — 대형 타이포
─────────────────────────────────────── */
.chapter2 {
  padding: clamp(60px, 10vw, 140px) 0;
  background: var(--bg);
  border-top: 1px solid var(--line-soft);
  border-bottom: 1px solid var(--line-soft);
  position: relative;
  overflow: hidden;
}

.chapter2-num {
  position: absolute;
  right: var(--pad);
  bottom: -20px;
  font-size: clamp(6rem, 16vw, 14rem);
  font-weight: 800;
  color: rgba(49,130,246,0.05);
  line-height: 1;
  letter-spacing: -0.04em;
  pointer-events: none;
}

/* ───────────────────────────────────────
   04. 프로젝트 — 좌우 2열
─────────────────────────────────────── */
.proj2-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 30px;
  margin-top: 60px;
  align-items: flex-start;
}

.proj2-left { flex: 1 1 400px; }
.proj2-right { flex: 1 1 360px; display: flex; flex-direction: column; gap: 16px; }

.proj2-meta {
  font-size: 0.82rem;
  color: var(--muted2);
  margin-bottom: 4px;
  line-height: 1.5;
}

.proj2-rule {
  border: none;
  border-top: 1px solid var(--line-soft);
  margin: 24px 0;
}

.kw2-wrap { margin-bottom: 24px; }
.kw2-label {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted3);
  margin-bottom: 10px;
  display: block;
}
.kw2-badges { display: flex; flex-wrap: wrap; gap: 8px; }
.kw2-badge {
  font-size: 0.8rem;
  font-weight: 700;
  color: var(--blue);
  background: rgba(49,130,246,0.08);
  border-radius: 100px;
  padding: 5px 14px;
}

.proj2-body {
  font-size: 1rem;
  color: var(--muted);
  line-height: 1.85;
  margin-bottom: 24px;
}

.proj2-quote {
  border-left: 3px solid var(--blue);
  padding-left: 18px;
  margin-bottom: 28px;
}

.proj2-quote p {
  font-size: 0.9rem;
  color: var(--muted2);
  line-height: 1.8;
  font-style: italic;
}

/* contrib */
.contrib2 { display: flex; flex-direction: column; gap: 10px; margin-top: 4px; }
.contrib2-item { display: flex; align-items: center; gap: 14px; }
.contrib2-lbl { font-size: 0.78rem; font-weight: 700; color: var(--muted3); min-width: 52px; }
.contrib2-track { flex: 1; height: 3px; background: var(--line-soft); border-radius: 2px; overflow: hidden; }
.contrib2-fill { height: 100%; background: var(--blue); border-radius: 2px; }

/* 스택 카드 */
.stack-card3 {
  background: var(--bg);
  border-radius: 12px;
  padding: 24px 28px;
  border: 1px solid var(--line-soft);
}

.stack-card3-title {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--muted3);
  margin-bottom: 16px;
}

.stack3-rows { display: flex; flex-direction: column; gap: 10px; }
.stack3-row { display: grid; grid-template-columns: 58px 1fr; gap: 12px; font-size: 0.88rem; line-height: 1.6; }
.stack3-layer { font-size: 0.72rem; font-weight: 700; color: var(--blue); letter-spacing: 0.04em; padding-top: 2px; }

/* 결과 카드 */
.result3-cards { display: flex; flex-direction: column; gap: 10px; }
.result3-card {
  background: var(--white);
  border-radius: 12px;
  padding: 18px 20px;
  box-shadow: 0 2px 12px rgba(0,0,0,0.05);
  border: 1px solid var(--line-soft);
}
.result3-card--accent { border-left: 3px solid var(--blue); }
.result3-lbl { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; color: var(--blue); margin-bottom: 5px; }
.result3-txt { font-size: 0.88rem; color: var(--dark2); line-height: 1.6; }

/* ───────────────────────────────────────
   05. 수치 강조 섹션 (토스 스타일 큰 숫자)
─────────────────────────────────────── */
.metrics2 {
  margin-top: 70px;
}

.metrics2-headline {
  font-size: clamp(2.4rem, 5vw, 4rem);
  font-weight: 700;
  line-height: 1.4;
  color: var(--dark);
  margin-bottom: 60px;
  letter-spacing: -0.02em;
}

.metrics2-headline span {
  display: block;
  color: var(--line);
}

.metrics2-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.metric3 {
  flex: 1 1 calc(33.333% - 1px);
  padding: 40px;
  border-right: 1px solid var(--line-soft);
  border-bottom: 1px solid var(--line-soft);
}

.metric3:nth-child(3n) { border-right: none; }
.metric3:nth-child(4), .metric3:nth-child(5), .metric3:nth-child(6) { border-bottom: none; }

.metric3-label {
  font-size: 0.82rem;
  font-weight: 700;
  color: var(--blue);
  letter-spacing: 0.06em;
  text-transform: uppercase;
  margin-bottom: 12px;
  display: block;
}

.metric3-num {
  font-size: clamp(2rem, 4vw, 3.2rem);
  font-weight: 700;
  color: var(--dark);
  line-height: 1.1;
  letter-spacing: -0.02em;
}

.metric3-num em { font-style: normal; color: var(--blue); }

.metric3-desc {
  font-size: 0.9rem;
  color: var(--muted2);
  margin-top: 8px;
  line-height: 1.6;
}

/* ───────────────────────────────────────
   06. AI 파이프라인 — 다크
─────────────────────────────────────── */
.pipe3 {
  margin-top: 56px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.08);
}

.pipe3-steps {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.pipe3-step {
  padding: 24px 12px;
  text-align: center;
  border-right: 1px solid rgba(255,255,255,0.08);
  position: relative;
}

.pipe3-step:last-child { border-right: none; }

.pipe3-step-num {
  font-size: 0.65rem;
  font-weight: 700;
  color: rgba(49,130,246,0.6);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 6px;
  display: block;
}

.pipe3-step-name {
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--white);
  line-height: 1.3;
  margin-bottom: 4px;
}

.pipe3-step-model {
  font-size: 0.65rem;
  color: rgba(255,255,255,0.35);
  letter-spacing: 0.04em;
}

.pipe3-arrow {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 12px;
  border-right: 1px solid rgba(255,255,255,0.08);
  color: rgba(49,130,246,0.5);
  font-size: 1.2rem;
}

.pipe3-result {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 0;
  border-top: 1px solid rgba(255,255,255,0.08);
}

.pipe3-callout {
  padding: 28px 28px;
  border-right: 1px solid rgba(255,255,255,0.08);
}

.pipe3-callout:last-child { border-right: none; }

.pipe3-callout-tag {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.35);
  margin-bottom: 8px;
  display: block;
}

.pipe3-callout-title {
  font-size: 1.05rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 8px;
}

.pipe3-callout-text {
  font-size: 0.85rem;
  color: rgba(255,255,255,0.5);
  line-height: 1.65;
}

/* ───────────────────────────────────────
   07. 대형 카피 섹션 (토스 스타일)
─────────────────────────────────────── */
.bigcopy {
  padding: clamp(80px, 12vw, 180px) 0;
  background: var(--white);
  border-top: 1px solid var(--line-soft);
  text-align: center;
}

.bigcopy-text {
  font-size: clamp(2.2rem, 5.5vw, 4.6rem);
  font-weight: 700;
  line-height: 1.4;
  color: var(--dark);
  letter-spacing: -0.02em;
  max-width: 860px;
  margin: 0 auto 48px;
}

.bigcopy-text em { font-style: normal; color: var(--blue); }

.bigcopy-num {
  font-size: clamp(3rem, 6vw, 5rem);
  font-weight: 700;
  color: var(--dark2);
  letter-spacing: -0.02em;
  margin-bottom: 8px;
}

.bigcopy-num em { font-style: normal; color: var(--line); }

.bigcopy-desc {
  font-size: 1.1rem;
  color: var(--muted2);
  font-weight: 600;
  line-height: 1.6;
}

/* ───────────────────────────────────────
   08. 강점 카드 (bg 섹션)
─────────────────────────────────────── */
.strength3-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20px;
  margin-top: 60px;
}

.strength3-card {
  flex: 1 1 calc(50% - 10px);
  min-width: 260px;
  background: var(--white);
  border-radius: 16px;
  padding: 40px;
  box-shadow: 0 2px 16px rgba(0,0,0,0.05);
  transition: box-shadow 0.2s, transform 0.2s;
}

.strength3-card:hover {
  box-shadow: 0 8px 40px rgba(0,0,0,0.1);
  transform: translateY(-2px);
}

.strength3-num {
  font-size: 2.2rem;
  font-weight: 800;
  color: var(--blue);
  opacity: 0.12;
  line-height: 1;
  margin-bottom: 16px;
  letter-spacing: -0.02em;
}

.strength3-title {
  font-size: 1.15rem;
  font-weight: 700;
  color: var(--dark);
  margin-bottom: 10px;
  line-height: 1.3;
}

.strength3-desc {
  font-size: 0.9rem;
  color: var(--muted2);
  line-height: 1.8;
}

.strength3-ev {
  display: block;
  margin-top: 8px;
  font-size: 0.78rem;
  color: var(--muted3);
  font-weight: 600;
  line-height: 1.5;
}

/* ───────────────────────────────────────
   09. ALL PROJECTS 아카이브
─────────────────────────────────────── */
.archive3 { margin-top: 60px; }

.archive3-group-label {
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--blue);
  margin-bottom: 12px;
}

.archive3-table {
  border-top: 2px solid var(--dark);
  margin-bottom: 48px;
}

.archive3-row {
  display: grid;
  grid-template-columns: 56px 1fr 150px 180px 28px;
  gap: 16px;
  padding: 18px 0;
  border-bottom: 1px solid var(--line-soft);
  align-items: center;
  text-decoration: none;
  color: inherit;
  transition: background 0.12s, padding 0.12s;
}

.archive3-row:hover {
  background: var(--bg);
  padding-left: 12px;
  padding-right: 12px;
  margin: 0 -12px;
}

.archive3-head .archive3-row {
  border-bottom: 1px solid var(--line);
}

.archive3-head .archive3-col {
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted3);
}

.archive3-num {
  font-size: 0.78rem;
  font-weight: 700;
  color: var(--blue);
  letter-spacing: 0.05em;
}

.archive3-title { font-size: 0.95rem; font-weight: 700; color: var(--dark); }
.archive3-role { font-size: 0.85rem; color: var(--muted2); }
.archive3-period { font-size: 0.85rem; color: var(--muted2); }
.archive3-link { font-size: 1rem; color: var(--muted3); text-align: right; }

/* ───────────────────────────────────────
   10. CLOSING — 토스 footer 스타일
─────────────────────────────────────── */
.closing3 {
  padding: clamp(80px, 12vw, 160px) 0 clamp(60px, 8vw, 100px);
  background: var(--white);
  border-top: 1px solid var(--line-soft);
  text-align: center;
}

.closing3-eyebrow {
